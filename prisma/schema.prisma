// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("student") // "admin" or "student"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments   Enrollment[]
  examResults   ExamResult[]
  payments      Payment[]
  subscriptions Subscription[]
}

// ECG Vault and other standalone subscriptions
model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  productId            String   // "ecg_vault", "premium", etc.
  stripeSubscriptionId String?  @unique // Stripe Subscription ID
  stripeCustomerId     String?  // Stripe Customer ID
  status               String   @default("inactive") // "active", "canceled", "past_due", "inactive"
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  price       Int      @default(0) // Price in cents, 0 = free
  prePostTestEnabled Boolean @default(false)
  preTestId   String?
  postTestId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections    Section[]
  videos      Video[]
  exams       Exam[]
  enrollments Enrollment[]
  payments    Payment[]
}

model Section {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int      @default(0)
  preTestId   String?  // Optional pre-test for this section
  postTestId  String?  // Optional post-test for this section
  videoCount  Int      @default(0) // Target number of videos for this section
  examWeight  Float?   // Percentage weight of this section on the exam (e.g., 30 for 30%)
  parentId    String?  // Parent section for hierarchical organization
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  parent      Section? @relation("SectionHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Section[] @relation("SectionHierarchy")
  videos      Video[]
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  filename    String
  duration    Int?     // in seconds
  order       Int      @default(0)
  courseId    String
  sectionId   String?  // Optional: assign video to a section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section     Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  progress    VideoProgress[]
}

model Exam {
  id          String   @id @default(cuid())
  title       String
  description String?
  courseId    String
  examType    String   @default("regular") // "regular", "pre-test", "post-test"
  passingScore Int     @default(70)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions   Question[]
  results     ExamResult[]
}

model Question {
  id          String   @id @default(cuid())
  examId      String
  question    String
  type        String   @default("multiple_choice") // "multiple_choice" or "true_false"
  options     String   // JSON array of options
  correctAnswer String
  explanation String?  // Explanation shown after post-test
  category    String?  // Topic/category (e.g., "Device Programming", "Rhythm Analysis", etc.)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  enrolledAt      DateTime @default(now())
  expiresAt       DateTime // Access ALWAYS expires after 1 year - no lifetime access
  hasPaid         Boolean  @default(false) // True if course is free or payment completed
  preTestCompleted  Boolean  @default(false)
  videosCompleted   Boolean  @default(false)
  postTestCompleted Boolean  @default(false)
  skipPrePostTest   Boolean  @default(false)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model VideoProgress {
  id          String   @id @default(cuid())
  userId      String
  videoId     String
  completed   Boolean  @default(false)
  watchedAt   DateTime @default(now())

  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

model ExamResult {
  id          String   @id @default(cuid())
  userId      String
  examId      String
  score       Int
  answers     String   // JSON object of answers
  passed      Boolean
  takenAt     DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model Payment {
  id                  String   @id @default(cuid())
  userId              String
  courseId            String
  stripeSessionId     String   @unique // Stripe Checkout Session ID
  stripePaymentId     String?  // Stripe Payment Intent ID
  stripeSubscriptionId String? // Stripe Subscription ID for payment plans
  amount              Int      // Amount in cents
  status              String   // "pending", "completed", "failed", "active", "canceled"
  paymentType         String   @default("one_time") // "one_time" or "subscription"
  installmentsPaid    Int      @default(0) // Number of installments paid (for subscriptions)
  totalInstallments   Int      @default(1) // Total installments (3 for payment plan, 1 for one-time)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}
